# Security Toolkit - Environment Variables
# Copy to .env and fill in your values.
# Place this file in your mcp-security-hub directory, or set paths below.

# ─── API Keys ───────────────────────────────────────────────────────────────────
# Required by specific Docker containers. Leave empty if you don't use them.

SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=
ZOOMEYE_API_KEY=
NETWORKSDB_API_KEY=

# ─── Wazuh SIEM ─────────────────────────────────────────────────────────────────
# Required for wazuh-mcp server (threat hunting / SIEM integration)

WAZUH_HOST=
WAZUH_PORT=55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=

# ─── Elasticsearch ──────────────────────────────────────────────────────────────
# Required for elasticsearch-mcp server (log analysis)

ES_HOST=http://localhost:9200

# ─── Tool Paths (optional overrides) ────────────────────────────────────────────
# Set these if your tools are installed in non-default locations.
# If unset, defaults from config/tools.yaml are used.

# SECURITY_HUB=C:/Users/slabl/Tools/mcp-security-hub
# CODEBADGER_DIR=C:/Users/slabl/Documents/Projects/codebadger
# GHIDRA_MCP_DIR=C:/Users/slabl/Tools/GhydraMCP
# SEMGREP_MCP_DIR=C:/Users/slabl/Tools/semgrep-mcp
# CYBERCHEF_DIR=C:/Users/slabl/Tools/CyberChef-MCP
# WAZUH_MCP_DIR=C:/Users/slabl/Tools/wazuh-mcp
# ES_MCP_DIR=C:/Users/slabl/Tools/elasticsearch-mcp
# DEOBFUSCATE_DIR=C:/Users/slabl/Tools/deobfuscate-mcp-server

# SLIVER_PATH=C:/Users/slabl/Tools/sliver/sliver-server.exe
# SEMGREP_PATH=C:/Users/slabl/Tools/semgrep-mcp/.venv/Scripts/semgrep.exe
# JADX_PATH=C:/Users/slabl/Tools/jadx/jadx-1.5.5/bin/jadx.bat
# ILSPY_PATH=C:/Users/slabl/Tools/ilspy/ILSpy/ILSpy.exe
# RETDEC_PATH=C:/Users/slabl/Tools/retdec/retdec-v5.0/bin/retdec-decompiler.exe
# JOERN_PATH=C:/Users/slabl/Tools/joern/joern-cli/joern
# TSHARK_PATH=C:/Program Files/Wireshark/tshark.exe
